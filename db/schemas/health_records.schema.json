{
	"bsonType": "object",
	"required": ["user_id", "record_date"],
	"permission": {
		"read": "doc.user_id == auth.uid",
		"create": "doc.user_id == auth.uid",
		"update": "doc.user_id == auth.uid",
		"delete": "doc.user_id == auth.uid"
	},
	"properties": {
		"_id": {
			"description": "记录唯一标识"
		},
		"user_id": {
			"bsonType": "string",
			"description": "用户 ID (关联 mom_users._id)",
			"title": "用户ID",
			"foreignKey": "mom_users._id"
		},
		"record_type": {
			"bsonType": "string",
			"description": "记录类型",
			"title": "记录类型",
			"enum": ["weight", "blood_pressure", "mood", "fetal_movement", "note", "combined"],
			"default": "combined"
		},
		"record_date": {
			"bsonType": "string",
			"description": "记录日期 YYYY-MM-DD 格式",
			"title": "记录日期"
		},
		"weight": {
			"bsonType": "string",
			"description": "体重 (kg)",
			"title": "体重"
		},
		"weight_unit": {
			"bsonType": "string",
			"description": "体重单位",
			"title": "体重单位",
			"default": "kg",
			"enum": ["kg", "斤", "lb"]
		},
		"systolic": {
			"bsonType": "int",
			"description": "收缩压 (高压 mmHg)",
			"title": "收缩压",
			"minimum": 60,
			"maximum": 250
		},
		"diastolic": {
			"bsonType": "int",
			"description": "舒张压 (低压 mmHg)",
			"title": "舒张压",
			"minimum": 40,
			"maximum": 150
		},
		"bp_text": {
			"bsonType": "string",
			"description": "血压文本 如 118/76",
			"title": "血压文本"
		},
		"is_abnormal": {
			"bsonType": "bool",
			"description": "是否异常",
			"title": "是否异常",
			"default": false
		},
		"mood": {
			"bsonType": "string",
			"description": "心情表情",
			"title": "心情"
		},
		"symptoms": {
			"bsonType": "array",
			"description": "今日症状列表",
			"title": "症状",
			"arrayType": "string"
		},
		"fetal_movement": {
			"bsonType": "string",
			"description": "胎动次数",
			"title": "胎动次数"
		},
		"note": {
			"bsonType": "string",
			"description": "备注信息",
			"title": "备注",
			"maxLength": 1000
		},
		"plans": {
			"bsonType": "array",
			"description": "今日计划列表",
			"title": "计划",
			"arrayType": "object"
		},
		"week_of_pregnancy": {
			"bsonType": "int",
			"description": "记录时的孕周",
			"title": "孕周"
		},
		"data_source": {
			"bsonType": "string",
			"description": "数据来源",
			"title": "数据来源",
			"enum": ["manual", "device", "import"],
			"default": "manual"
		},
		"create_time": {
			"bsonType": "timestamp",
			"description": "创建时间",
			"title": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"update_time": {
			"bsonType": "timestamp",
			"description": "更新时间",
			"title": "更新时间"
		}
	}
}