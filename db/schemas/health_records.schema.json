{
	"bsonType": "object",
	"required": ["user_id", "record_date"],
	"permission": {
		"read": "doc.user_id == auth.uid",
		"create": "doc.user_id == auth.uid",
		"update": "doc.user_id == auth.uid",
		"delete": "doc.user_id == auth.uid"
	},
	"properties": {
		"_id": {
			"description": "记录唯一标识"
		},
		"user_id": {
			"bsonType": "string",
			"description": "用户 ID (关联 mom_users._id)",
			"title": "用户ID",
			"foreignKey": "mom_users._id"
		},
		"record_type": {
			"bsonType": "string",
			"description": "记录类型",
			"title": "记录类型",
			"enum": ["weight", "blood_pressure", "both"],
			"default": "both"
		},
		"record_date": {
			"bsonType": "date",
			"description": "记录日期时间",
			"title": "记录时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"weight": {
			"bsonType": "decimal",
			"description": "体重 (kg)",
			"title": "体重",
			"minimum": 30,
			"maximum": 200
		},
		"weight_unit": {
			"bsonType": "string",
			"description": "体重单位",
			"title": "体重单位",
			"default": "kg",
			"enum": ["kg", "斤", "lb"]
		},
		"systolic": {
			"bsonType": "int",
			"description": "收缩压 (高压 mmHg)",
			"title": "收缩压",
			"minimum": 60,
			"maximum": 250
		},
		"diastolic": {
			"bsonType": "int",
			"description": "舒张压 (低压 mmHg)",
			"title": "舒张压",
			"minimum": 40,
			"maximum": 150
		},
		"is_abnormal": {
			"bsonType": "bool",
			"description": "是否异常 (收缩压>140 或 舒张压>90)",
			"title": "是否异常",
			"default": false
		},
		"abnormal_type": {
			"bsonType": "array",
			"description": "异常类型列表",
			"title": "异常类型",
			"arrayType": "string",
			"enum": ["high_systolic", "high_diastolic", "low_systolic", "low_diastolic", "high_weight", "low_weight"]
		},
		"week_of_pregnancy": {
			"bsonType": "int",
			"description": "记录时的孕周",
			"title": "孕周"
		},
		"notes": {
			"bsonType": "string",
			"description": "备注信息",
			"title": "备注",
			"maxLength": 500
		},
		"data_source": {
			"bsonType": "string",
			"description": "数据来源",
			"title": "数据来源",
			"enum": ["manual", "device", "import"],
			"default": "manual"
		},
		"create_time": {
			"bsonType": "date",
			"description": "创建时间",
			"title": "创建时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"update_time": {
			"bsonType": "date",
			"description": "更新时间",
			"title": "更新时间"
		}
	}
}
