{
	"bsonType": "object",
	"required": ["openid"],
	"permission": {
		"read": true,
		"create": false,
		"update": false,
		"delete": false
	},
	"properties": {
		"_id": {
			"description": "用户唯一标识"
		},
		"openid": {
			"bsonType": "string",
			"description": "微信小程序 openid",
			"title": "OpenID",
			"trim": "both"
		},
		"unionid": {
			"bsonType": "string",
			"description": "微信开放平台 unionid",
			"title": "UnionID"
		},
		"nickname": {
			"bsonType": "string",
			"description": "用户昵称",
			"title": "昵称",
			"maxLength": 50
		},
		"avatar": {
			"bsonType": "string",
			"description": "用户头像 URL",
			"title": "头像"
		},
		"phone": {
			"bsonType": "string",
			"description": "手机号",
			"title": "手机号",
			"pattern": "^1[3-9]\\d{9}$"
		},
		"lmp_date": {
			"bsonType": "date",
			"description": "末次月经时间 (Last Menstrual Period)",
			"title": "末次月经"
		},
		"due_date": {
			"bsonType": "date",
			"description": "预产期 (LMP + 280天)",
			"title": "预产期"
		},
		"current_week": {
			"bsonType": "int",
			"description": "当前孕周 (计算得出)",
			"title": "当前孕周"
		},
		"current_day": {
			"bsonType": "int",
			"description": "当前孕周的第几天 (0-6)",
			"title": "孕周日"
		},
		"is_vip": {
			"bsonType": "bool",
			"description": "是否为 VIP 会员",
			"title": "VIP状态",
			"default": false
		},
		"vip_level": {
			"bsonType": "string",
			"description": "VIP 等级 (monthly, yearly, lifetime)",
			"title": "VIP等级",
			"enum": ["monthly", "yearly", "lifetime"]
		},
		"vip_start_time": {
			"bsonType": "date",
			"description": "VIP 开始时间",
			"title": "VIP开始时间"
		},
		"vip_expire_time": {
			"bsonType": "date",
			"description": "VIP 过期时间",
			"title": "VIP过期时间"
		},
		"ai_quota_monthly": {
			"bsonType": "int",
			"description": "每月免费 AI 解读次数配额",
			"title": "月度AI配额",
			"default": 3
		},
		"ai_used_current_month": {
			"bsonType": "int",
			"description": "本月已使用 AI 解读次数",
			"title": "本月已用AI次数",
			"default": 0
		},
		"ai_quota_reset_date": {
			"bsonType": "date",
			"description": "AI 配额下次重置日期",
			"title": "配额重置日期"
		},
		"preferred_llm": {
			"bsonType": "string",
			"description": "用户首选的大语言模型",
			"title": "首选LLM",
			"enum": ["deepseek", "qwen", "kimi"],
			"default": "deepseek"
		},
		"storage_used": {
			"bsonType": "int",
			"description": "已使用存储空间 (字节)",
			"title": "已用存储",
			"default": 0
		},
		"storage_limit": {
			"bsonType": "int",
			"description": "存储空间限制 (字节，0表示无限)",
			"title": "存储限制",
			"default": 104857600
		},
		"reminder_enabled": {
			"bsonType": "bool",
			"description": "是否开启产检提醒",
			"title": "产检提醒开关",
			"default": true
		},
		"reminder_time": {
			"bsonType": "string",
			"description": "每日提醒时间 (HH:mm)",
			"title": "提醒时间",
			"default": "09:00"
		},
		"is_postpartum": {
			"bsonType": "bool",
			"description": "是否已进入产后模式",
			"title": "产后模式",
			"default": false
		},
		"baby_birth_date": {
			"bsonType": "date",
			"description": "宝宝出生日期",
			"title": "宝宝出生日期"
		},
		"status": {
			"bsonType": "int",
			"description": "账号状态 (0:正常, 1:禁用)",
			"title": "账号状态",
			"default": 0
		},
		"last_login_time": {
			"bsonType": "date",
			"description": "最后登录时间",
			"title": "最后登录时间"
		},
		"create_time": {
			"bsonType": "date",
			"description": "注册时间",
			"title": "注册时间",
			"forceDefaultValue": {
				"$env": "now"
			}
		},
		"update_time": {
			"bsonType": "date",
			"description": "更新时间",
			"title": "更新时间"
		}
	}
}
